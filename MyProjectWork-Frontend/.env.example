# =============================================================================
# Frontend environment variables — example file.
#
# Copy to `.env.local` (gitignored, dev override) or set these in your
# deployment platform (Vercel / Netlify / Docker / etc.) before running
# `npm run build` for production.
#
# Only variables prefixed with VITE_ are exposed to client code.
# =============================================================================

# Base URL of the Spring Boot API (no trailing slash).
#   Dev    : http://localhost:8085
#   Prod   : https://api.your-domain.com
VITE_API_BASE_URL=http://localhost:8085

# Path segment used to fetch trainee profile photos.
VITE_PROFILE_PHOTO_PATH=/trainee/profile-photo

# Default page size for paginated list views.
VITE_DEFAULT_PAGE_SIZE=10
