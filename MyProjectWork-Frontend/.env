# =============================================================================
# Frontend environment variables — Vite picks these up at build time.
#
# Only variables prefixed with VITE_ are exposed to client code via
# `import.meta.env.VITE_*`. Reference these from src/config.js, never inline.
#
# This file is committed and contains DEV DEFAULTS. To override locally,
# create `.env.local` (gitignored). For production deploys, supply
# environment-specific values via your CI/CD provider or by setting them
# in the shell before running `npm run build`.
# =============================================================================

# Base URL of the Spring Boot API (no trailing slash).
VITE_API_BASE_URL=http://localhost:8086

# Path segment used to fetch trainee profile photos. Combined with the API
# base URL at runtime as `${VITE_API_BASE_URL}${VITE_PROFILE_PHOTO_PATH}/{id}`.
VITE_PROFILE_PHOTO_PATH=/trainee/profile-photo

# Default page size for paginated list views.
VITE_DEFAULT_PAGE_SIZE=10
