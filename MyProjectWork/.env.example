# =============================================================================
# Backend environment variables — example file.
#
# Spring Boot reads these via `${ENV_VAR:default}` placeholders in
# `application.properties`. Set them in your deployment platform's secret
# manager, your shell, or a `.env` file consumed by your container runtime
# (e.g. docker run --env-file .env).
#
# Spring Boot does NOT auto-load a .env file from disk — it reads from the
# JVM/process environment. Don't commit a real `.env` to git.
# =============================================================================

# ─── Database ────────────────────────────────────────────────────────────────
# JDBC URL with options. Example for cloud RDS / managed MySQL:
#   jdbc:mysql://my-prod-db.eu-west-1.rds.amazonaws.com:3306/gencdossier?useSSL=true&serverTimezone=UTC
DB_URL=jdbc:mysql://localhost:3306/demodb?createDatabaseIfNotExist=true&useSSL=false&serverTimezone=UTC
DB_USERNAME=root
DB_PASSWORD=replace-me

# ─── JPA / Hibernate ─────────────────────────────────────────────────────────
# In production, prefer `validate` (or `none`) — never `update`/`create`.
JPA_DDL_AUTO=update
JPA_SHOW_SQL=true

# ─── Server ──────────────────────────────────────────────────────────────────
SERVER_PORT=8085

# ─── File uploads ────────────────────────────────────────────────────────────
# Absolute path is recommended in production (e.g. /var/lib/gencdossier/photos)
# so it survives redeploys.
FILE_UPLOAD_DIR=./candidate_profile

# ─── JWT Authentication ──────────────────────────────────────────────────────
# REQUIRED in production. Generate with: openssl rand -base64 64
JWT_SECRET=4db418603a909c5f5771946577284492db2e39d50633ee73e59bed0702c0ae2d59cfac3420a186ec0dc167daaf4a317c843ede559472b27f1d6b0970468f0edc
# Token expiry in ms (default 24h)
JWT_EXPIRATION_MS=86400000

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list. Use only the origins your real frontend is served from.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000

# ─── Pagination ──────────────────────────────────────────────────────────────
APP_PAGE_SIZE=10

# ─── Multipart upload limits ─────────────────────────────────────────────────
MAX_FILE_SIZE=20MB
MAX_REQUEST_SIZE=20MB

# ─── Spring profile ──────────────────────────────────────────────────────────
# Activate the prod profile to load application-prod.properties overrides.
# SPRING_PROFILES_ACTIVE=prod
